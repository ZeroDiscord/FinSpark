# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=finspark

# Legacy SQL config (deprecated; leave blank when using Mongo-only)
DATABASE_URL=

# JWT
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-different-from-above
JWT_REFRESH_EXPIRES_IN=7d

# ML Service
ML_BASE_URL=http://localhost:8000
ML_API_KEY=dev-secret-key

# APK Parser (path to apktool.jar on server)
APKTOOL_JAR_PATH=/usr/local/bin/apktool.jar
APK_UPLOAD_DIR=./uploads/apk
CSV_UPLOAD_DIR=./uploads/csv

# Asana OAuth
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
ASANA_REDIRECT_URI=http://localhost:3001/api/asana/oauth/callback
ASANA_TOKEN_ENCRYPTION_KEY=0000000000000000000000000000000000000000000000000000000

# PII Salt (must match ML/config.yaml pii_salt)
PII_SALT=CHANGE_ME

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173
